root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,svelte,css,json,md,yml,yaml}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
