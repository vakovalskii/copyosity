{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "endOfLine": "lf",
  "sortImports": {},
  "sortPackageJson": true,
  "ignorePatterns": [
    "dist/**",
    "build/**",
    ".svelte-kit/**",
    "node_modules/**",
    "src-tauri/**",
    "package-lock.json",
    ".vscode/**"
  ]
}
