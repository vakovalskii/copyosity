{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copyosity",
  "version": "0.9.9",
  "identifier": "com.vkovalskii.copyosity",
  "build": {
    "beforeDevCommand": "bash scripts/with-npm.sh npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash scripts/with-npm.sh npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src ipc: http://ipc.localhost http://localhost:* https://localhost:* https://api.neuraldeep.ru https://*.neuraldeep.ru"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Valeriy Kovalsky (A933C2TJXU)",
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://vkovalskii.com/copyosity/latest.json",
        "https://github.com/vakovalskii/copyosity/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFM0QzODE3MjUxQjIwNzUKUldSMUlCc2xGemc5bnE2eUpFMEppanVYMi9aM0tSVi9xSzY1QmltUVJadkNCNmdKM3FVWUg2KzcK"
    }
  }
}
